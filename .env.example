# Local Node server
NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# Browser origins allowed by Socket.IO/CORS in local development.
# Separate several exact origins with commas; avoid wildcard in production.
CLIENT_ORIGIN=http://localhost:5173

# Vite embeds this value at build time. Empty means same-origin (recommended behind nginx).
VITE_SERVER_URL=http://localhost:3001

# Docker Compose host ports and public origin.
CLIENT_BIND=0.0.0.0
CLIENT_PORT=8080
SERVER_BIND=127.0.0.1
SERVER_PORT=3001
PUBLIC_ORIGIN=http://localhost:8080
